# iot-mock/.env — fill in your Supabase credentials
# Get these from your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Device identity (must match the row in Supabase `devices` table)
DEVICE_ID=aquaedge-01
DEVICE_NAME=Development Mock
FIRMWARE_VERSION=mock-1.0.0

# Simulation tuning
TICK_INTERVAL_SEC=5
SOIL_MOISTURE_START=60.0
SOIL_FERTILITY_START=3.5
WATER_LEVEL=SUFFICIENT

# Optional: start with a specific sensor already failed (comma-separated)
# SENSOR_FAILURES=soil_moisture,air
