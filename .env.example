# PostgreSQL connection string from Supabase.
# Do not use SUPABASE_URL or SUPABASE_SERVICE_KEY in this mock.
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Device identity. Must match "Device"."deviceCode".
DEVICE_CODE=aquaedge-01

# Simulation tuning
TICK_INTERVAL_SEC=5
SOIL_MOISTURE_START=60.0
SOIL_FERTILITY_START=3.5
WATER_LEVEL=FULL
